{
    "manifest_version": 3,
    "name": "Nexus",
    "version": "1.0.0",
    "description": "Save anything to your Nexus knowledge base",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "https://nexus-backend-v7ki.onrender.com/*",
        "https://nexus-ebon-eight.vercel.app/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Save to Nexus"
    },
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    }
}
